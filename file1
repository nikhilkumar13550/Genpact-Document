from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware
from pydantic import BaseModel
import time

# Initialize the FastAPI app
app = FastAPI()

# VERY IMPORTANT: This allows your React frontend (localhost:5173/5174) 
# to talk to your Python backend (localhost:8000) without security blocks.
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],  # Allows all origins for development
    allow_credentials=True,
    allow_methods=["*"],  # Allows all methods (POST, GET, etc.)
    allow_headers=["*"],
)

# Define what the incoming data from React looks like
class ChatRequest(BaseModel):
    query: str
    userId: str = "default_user"

# A small "mock" Knowledge Base database for the prototype
MOCK_KNOWLEDGE_BASE = {
    "password": "To reset a user's password, navigate to Tech Central > Access Management. Verify their employee ID before sending the reset link.",
    "pto": "According to the Manulife HR policy, Paid Time Off (PTO) requests must be submitted through Workday at least 14 days in advance.",
    "escalation": "For Tier 2 technical escalations, please create a Jira ticket and assign it to the 'Ops-Infra' queue."
}

# The actual endpoint that React talks to
@app.post("/api/chat")
def chat_endpoint(request: ChatRequest):
    user_question = request.query.lower()
    
    # 1. Simulate the time it takes an AI to "think" and search a database
    time.sleep(1.5) 
    
    # 2. Search our mock database for keywords
    answer = "I'm sorry, I couldn't find an SOP for that specific request in the Manulife Knowledge Base. Could you rephrase?"
    
    for keyword, sop_text in MOCK_KNOWLEDGE_BASE.items():
        if keyword in user_question:
            answer = f"I found a relevant policy! {sop_text}"
            break

    # 3. Send the answer back to the React frontend
    return {"answer": answer}

# This allows you to run the file directly
if __name__ == "__main__":
    import uvicorn
    uvicorn.run(app, host="0.0.0.0", port=8000)
