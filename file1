import React, { useState, useRef, useEffect } from 'react';
import { 
  Home, Building2, BookOpen, Users, Scale, ShieldAlert,
  Search, Globe, Send, User, Bot, HelpCircle
} from 'lucide-react';
import './App.css';

export default function App() {
  const [messages, setMessages] = useState([
    { 
      id: 1, 
      text: "Hi, Nikhil! Welcome to the Ops Knowledge Base. How can I help you resolve a query or locate an SOP today?", 
      sender: "bot" 
    }
  ]);
  const [inputValue, setInputValue] = useState("");
  const [isLoading, setIsLoading] = useState(false);
  const messagesEndRef = useRef(null);

  const scrollToBottom = () => {
    messagesEndRef.current?.scrollIntoView({ behavior: "smooth" });
  };

  useEffect(() => {
    scrollToBottom();
  }, [messages]);

  const handleSend = async () => {
    if (!inputValue.trim() || isLoading) return;

    const userText = inputValue;
    
    // 1. Show user message
    const newUserMsg = { id: Date.now(), text: userText, sender: "user" };
    setMessages(prev => [...prev, newUserMsg]);
    setInputValue("");
    setIsLoading(true);

    try {
      // 2. Call the Python Backend
      const response = await fetch('http://localhost:8000/api/chat', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ 
          query: userText,
          userId: "nikhil_123"
        }),
      });

      if (!response.ok) throw new Error("Network error");
      const data = await response.json();
      
      // 3. Show real bot response
      setMessages(prev => [...prev, { id: Date.now() + 1, text: data.answer, sender: "bot" }]);

    } catch (error) {
      setMessages(prev => [...prev, { 
        id: Date.now() + 1, 
        text: "⚠️ Backend is not running! Please start the Python server.", 
        sender: "bot" 
      }]);
    } finally {
      setIsLoading(false);
    }
  };

  return (
    <div className="app-layout">
      {/* LEFT SIDEBAR */}
      <div className="sidebar">
        <div className="nav-item active"><Home size={24} /></div>
        <div className="nav-item"><Building2 size={24} /><span className="nav-label">Our Company</span></div>
        <div className="nav-item"><BookOpen size={24} /><span className="nav-label">Employee<br/>Resources</span></div>
        <div className="nav-item"><Users size={24} /><span className="nav-label">Company<br/>Directory</span></div>
        <div className="nav-item"><Scale size={24} /><span className="nav-label">Code of<br/>Conduct</span></div>
        <div className="nav-item"><ShieldAlert size={24} /><span className="nav-label">Ethics Hotline</span></div>
      </div>

      {/* MAIN CONTENT AREA */}
      <div className="main-content">
        <header className="top-header">
          <div className="brand-area">
            <span className="brand-text">III Manulife</span>
            <span style={{color: '#ccc'}}>|</span>
            <span className="brand-subtext">John Hancock</span>
          </div>
          <div className="header-actions">
            <Search className="header-icon" size={20} />
            <div style={{ display: 'flex', alignItems: 'center', gap: '4px', cursor: 'pointer' }}>
              <span>EN</span><Globe size={16} />
            </div>
          </div>
        </header>

        <div className="chat-workspace">
          <div className="chat-container">
            <div className="chat-header-internal">
              <HelpCircle size={24} color="#007A33" />
              <h2>Ops Knowledge Assistant</h2>
            </div>
            
            <div className="messages-area">
              {messages.map((msg) => (
                <div key={msg.id} className={`message-wrapper ${msg.sender}`}>
                  <div className={`avatar ${msg.sender === 'bot' ? 'bot-avatar' : 'user-avatar'}`}>
                    {msg.sender === 'bot' ? <Bot size={20} /> : <User size={20} />}
                  </div>
                  <div className="message-bubble">{msg.text}</div>
                </div>
              ))}
              <div ref={messagesEndRef} />
            </div>

            <div className="input-area">
              <input 
                type="text" 
                className="chat-input" 
                placeholder="Ask about an SOP..." 
                value={inputValue}
                onChange={(e) => setInputValue(e.target.value)}
                onKeyDown={(e) => e.key === 'Enter' && handleSend()}
                disabled={isLoading}
              />
              <button 
                className="send-btn" 
                onClick={handleSend} 
                disabled={isLoading}
                style={{ opacity: isLoading ? 0.7 : 1 }}
              >
                <Send size={18} />
                {isLoading ? 'Thinking...' : 'Send'}
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  );
}
