from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware
from pydantic import BaseModel
import requests
import urllib3
import logging
from azure.identity import InteractiveBrowserCredential

# 1. Hide the annoying warnings in the terminal
urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)
logging.getLogger("azure.identity").setLevel(logging.ERROR) # Hides that form_post warning!

app = FastAPI()

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

# 2. Base URL ONLY (Removed the ?api-version= from the string)
FOUNDRY_ENDPOINT = "https://claims-intake.services.ai.azure.com/api/projects/firstProject/applications/KbChatBot/protocols/openai/responses"

# 3. Secure Enterprise Auth
credential = InteractiveBrowserCredential(connection_verify=False)

class ChatRequest(BaseModel):
    query: str
    userId: str = "manulife_ops_user"

@app.post("/api/chat")
def chat_endpoint(request: ChatRequest):
    try:
        token_obj = credential.get_token("https://ai.azure.com/.default")
        token = token_obj.token

        headers = {
            "Content-Type": "application/json",
            "Authorization": f"Bearer {token}"
        }

        # 4. Ajay's specific Foundry payload format
        payload = {
            "input": [
                {
                    "role": "user",
                    "content": [
                        {
                            "type": "input_text", 
                            "text": request.query
                        }
                    ]
                }
            ]
        }

        print(f"Sending query using Foundry format: '{request.query}' ...")
        
        # 5. THE FIX: Pass api-version explicitly in the params argument!
        response = requests.post(
            FOUNDRY_ENDPOINT, 
            headers=headers, 
            json=payload, 
            params={"api-version": "2025-11-15-preview"}, 
            verify=False
        )
        
        if response.status_code not in [200, 201]:
            print(f"AZURE ERROR BODY: {response.text}")
            return {"answer": f"⚠️ Azure Error {response.status_code}. See Python terminal."}

        data = response.json()
        
        # 6. Parse the Foundry response exactly how Ajay does
        parts = []
        for item in data.get("output", []):
            if isinstance(item, dict) and item.get("type") == "message":
                for c in item.get("content", []):
                    if c.get("type") in ("text", "output_text") and c.get("text"):
                        parts.append(c["text"])
        
        if parts:
            bot_text = "\n\n".join(parts)
            return {"answer": bot_text}
            
        return {"answer": "⚠️ Received a response, but couldn't find the text. Check terminal."}

    except Exception as e:
        print(f"Python Error: {e}")
        return {"answer": f"⚠️ Python connection error: {str(e)}"}

if __name__ == "__main__":
    import uvicorn
    uvicorn.run(app, host="0.0.0.0", port=8000)
